<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TOrderMapper">
    
    <resultMap type="TOrder" id="TOrderResult">
        <id property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="totalAmount"    column="total_amount"    />
        <result property="status"    column="status"    />
        <result property="orderTime"    column="order_time"    />
        <result property="completeTime"    column="complete_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap type="TOrder" id="TOrderWithItemsResult" extends="TOrderResult">
        <collection property="orderItems" ofType="TOrderItem" resultMap="TOrderItemNestedResult"/>
    </resultMap>

    <resultMap type="TOrderItem" id="TOrderItemNestedResult">
        <id property="orderItemId" column="order_item_id" />
        <result property="orderId" column="item_order_id" />
        <result property="dishId" column="dish_id" />
        <result property="dishName" column="dish_name" />
        <result property="price" column="item_price" />
        <result property="quantity" column="item_quantity" />
    </resultMap>

    <sql id="selectTOrderVo">
        select order_id, order_no, total_amount, status, order_time, complete_time, del_flag, create_by, create_time, update_by, update_time, remark from t_order
    </sql>

    <sql id="selectTOrderWithItemsVo">
        select
            o.order_id, o.order_no, o.total_amount, o.status, o.order_time, o.complete_time, o.del_flag,
            o.create_by, o.create_time, o.update_by, o.update_time, o.remark,
            i.order_item_id, i.order_id as item_order_id, i.dish_id, i.dish_name,
            i.price as item_price, i.quantity as item_quantity
        from t_order o
        left join t_order_item i on o.order_id = i.order_id
    </sql>

    <select id="selectTOrderList" parameterType="TOrder" resultMap="TOrderResult">
        <include refid="selectTOrderVo"/>
        <where>  
            <if test="orderNo != null  and orderNo != ''"> and order_no like concat('%', #{orderNo}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
            <if test="orderTime != null "> and DATE(order_time) = #{orderTime}</if>
            <if test="completeTime != null "> and DATE(complete_time) = #{completeTime}</if>
        </where>
    </select>
    
    <select id="selectTOrderByOrderId" parameterType="Long" resultMap="TOrderWithItemsResult">
        <include refid="selectTOrderWithItemsVo"/>
        where o.order_id = #{orderId}
    </select>

    <insert id="insertTOrder" parameterType="TOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into t_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            <if test="orderTime != null">order_time,</if>
            <if test="completeTime != null">complete_time,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="orderTime != null">#{orderTime},</if>
            <if test="completeTime != null">#{completeTime},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTOrder" parameterType="TOrder">
        update t_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="orderTime != null">order_time = #{orderTime},</if>
            <if test="completeTime != null">complete_time = #{completeTime},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteTOrderByOrderId" parameterType="Long">
        delete from t_order where order_id = #{orderId}
    </delete>

    <delete id="deleteTOrderByOrderIds" parameterType="String">
        delete from t_order where order_id in 
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>