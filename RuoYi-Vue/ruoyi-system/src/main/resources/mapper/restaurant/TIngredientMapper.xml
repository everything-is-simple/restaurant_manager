<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TIngredientMapper">
    
    <resultMap type="TIngredient" id="TIngredientResult">
        <result property="ingredientId"    column="ingredient_id"    />
        <result property="name"    column="name"    />
        <result property="unit"    column="unit"    />
        <result property="safetyStock"    column="safety_stock"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTIngredientVo">
        select ingredient_id, name, unit, safety_stock, status, del_flag, create_by, create_time, update_by, update_time, remark from t_ingredient
    </sql>

    <select id="selectTIngredientList" parameterType="TIngredient" resultMap="TIngredientResult">
        <include refid="selectTIngredientVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="unit != null  and unit != ''"> and unit = #{unit}</if>
            <if test="safetyStock != null "> and safety_stock = #{safetyStock}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTIngredientByIngredientId" parameterType="Long" resultMap="TIngredientResult">
        <include refid="selectTIngredientVo"/>
        where ingredient_id = #{ingredientId}
    </select>

    <insert id="insertTIngredient" parameterType="TIngredient" useGeneratedKeys="true" keyProperty="ingredientId">
        insert into t_ingredient
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="unit != null and unit != ''">unit,</if>
            <if test="safetyStock != null">safety_stock,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="unit != null and unit != ''">#{unit},</if>
            <if test="safetyStock != null">#{safetyStock},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTIngredient" parameterType="TIngredient">
        update t_ingredient
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="unit != null and unit != ''">unit = #{unit},</if>
            <if test="safetyStock != null">safety_stock = #{safetyStock},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where ingredient_id = #{ingredientId}
    </update>

    <delete id="deleteTIngredientByIngredientId" parameterType="Long">
        delete from t_ingredient where ingredient_id = #{ingredientId}
    </delete>

    <delete id="deleteTIngredientByIngredientIds" parameterType="String">
        delete from t_ingredient where ingredient_id in 
        <foreach item="ingredientId" collection="array" open="(" separator="," close=")">
            #{ingredientId}
        </foreach>
    </delete>
</mapper>