<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TInventoryMapper">
    
    <resultMap type="TInventory" id="TInventoryResult">
        <result property="inventoryId"    column="inventory_id"    />
        <result property="ingredientId"    column="ingredient_id"    />
        <result property="stock"    column="stock"    />
        <result property="ingredientName"    column="ingredient_name"    />
        <result property="unit"    column="unit"    />
        <result property="safetyStock"    column="safety_stock"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTInventoryVo">
        select i.inventory_id, i.ingredient_id, i.stock, i.del_flag, i.create_by, i.create_time, i.update_by, i.update_time, i.remark,
               ing.name as ingredient_name, ing.unit, ing.safety_stock
        from t_inventory i
        left join t_ingredient ing on i.ingredient_id = ing.ingredient_id
    </sql>

    <select id="selectTInventoryList" parameterType="TInventory" resultMap="TInventoryResult">
        <include refid="selectTInventoryVo"/>
        <where>  
            <if test="ingredientId != null "> and i.ingredient_id = #{ingredientId}</if>
            <if test="stock != null "> and i.stock = #{stock}</if>
            <if test="ingredientName != null and ingredientName != ''"> and ing.name like concat('%', #{ingredientName}, '%')</if>
        </where>
    </select>
    
    <select id="selectTInventoryByInventoryId" parameterType="Long" resultMap="TInventoryResult">
        <include refid="selectTInventoryVo"/>
        where i.inventory_id = #{inventoryId}
    </select>

    <insert id="insertTInventory" parameterType="TInventory" useGeneratedKeys="true" keyProperty="inventoryId">
        insert into t_inventory
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ingredientId != null">ingredient_id,</if>
            <if test="stock != null">stock,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ingredientId != null">#{ingredientId},</if>
            <if test="stock != null">#{stock},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTInventory" parameterType="TInventory">
        update t_inventory
        <trim prefix="SET" suffixOverrides=",">
            <if test="ingredientId != null">ingredient_id = #{ingredientId},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where inventory_id = #{inventoryId}
    </update>

    <delete id="deleteTInventoryByInventoryId" parameterType="Long">
        delete from t_inventory where inventory_id = #{inventoryId}
    </delete>

    <delete id="deleteTInventoryByInventoryIds" parameterType="String">
        delete from t_inventory where inventory_id in
        <foreach item="inventoryId" collection="array" open="(" separator="," close=")">
            #{inventoryId}
        </foreach>
    </delete>

    <!-- 按食材ID扣减库存（防并发超扣：WHERE stock >= deductQty） -->
    <update id="deductStock">
        update t_inventory set stock = stock - #{deductQty}
        where ingredient_id = #{ingredientId} and stock >= #{deductQty}
    </update>

    <!-- 按食材ID增加库存（退单回滚用） -->
    <update id="addStock">
        update t_inventory set stock = stock + #{addQty}
        where ingredient_id = #{ingredientId}
    </update>

    <!-- 库存预警列表：当前库存 < 安全库存 -->
    <select id="selectWarningList" resultMap="TInventoryResult">
        <include refid="selectTInventoryVo"/>
        where i.del_flag = '0'
          and ing.del_flag = '0'
          and ing.safety_stock > 0
          and i.stock &lt; ing.safety_stock
        order by (ing.safety_stock - i.stock) desc
    </select>

    <!-- 库存预警条数 -->
    <select id="countWarning" resultType="int">
        select COUNT(*)
        from t_inventory i
        inner join t_ingredient ing on i.ingredient_id = ing.ingredient_id
        where i.del_flag = '0'
          and ing.del_flag = '0'
          and ing.safety_stock > 0
          and i.stock &lt; ing.safety_stock
    </select>
</mapper>